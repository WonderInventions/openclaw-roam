{
  "name": "group_mention_top_level",
  "summary": "Alice @-mentions the bot at top level in a group both share. Plugin replies at top level.",

  "setup": {
    "actor": "alice",
    "chatType": "group",
    "groupName": "OC mention top",
    "botIsMember": true,
    "trigger": { "text": "<@<bot.addrId>> what do you think?" }
  },

  "webhook": {
    "body": {
      "type": "message",
      "contentType": "text",
      "userId": "<alice.addrId>",
      "chatId": "<chat.id>",
      "chatType": "group",
      "text": "<assertText:contains:what do you think?>",
      "timestamp": "<gen.now>"
    }
  },

  "expectedApiCalls": [
    {
      "name": "typing in chat",
      "method": "POST",
      "path": "/v1/chat.typing",
      "body": { "chatId": "<chat.id>" }
    },
    {
      "name": "fetch chat history",
      "method": "GET",
      "path": "/v1/chat.history",
      "query": { "chatId": "<chat.id>", "limit": "20" }
    },
    {
      "name": "reply at top level",
      "method": "POST",
      "path": "/v1/chat.post",
      "body": {
        "chatId": "<chat.id>",
        "text": "<assertText:nonEmpty>",
        "markdown": true,
        "sync": true
      }
    }
  ]
}
