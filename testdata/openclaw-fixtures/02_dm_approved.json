{
  "name": "dm_approved",
  "summary": "Alice DMs the bot again in an existing DM chat. Plugin replies at top level.",

  "setup": {
    "actor": "alice",
    "chatType": "dm",
    "thread": { "parentActor": "alice", "parentText": "first contact" },
    "trigger": { "text": "follow up" }
  },

  "webhook": {
    "body": {
      "type": "message",
      "contentType": "text",
      "userId": "<alice.addrId>",
      "chatId": "<chat.id>",
      "chatType": "dm",
      "text": "<assertText:contains:follow up>",
      "timestamp": "<gen.now>"
    }
  },

  "expectedApiCalls": [
    {
      "name": "typing in DM",
      "method": "POST",
      "path": "/v1/chat.typing",
      "body": { "chatId": "<chat.id>" }
    },
    {
      "name": "reply at top level",
      "method": "POST",
      "path": "/v1/chat.post",
      "body": {
        "chatId": "<chat.id>",
        "text": "<assertText:nonEmpty>",
        "markdown": true,
        "sync": true
      }
    }
  ]
}
